generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model OmmRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  noradCatId         String   @map("norad_cat_id")
  objectId           String?  @map("object_id")
  objectName         String?  @map("object_name")
  classificationType String?  @map("classification_type")
  epoch              DateTime
  meanMotion         Float    @map("mean_motion")
  eccentricity       Float
  inclination        Float
  raOfAscNode        Float    @map("ra_of_asc_node")
  argOfPericenter    Float    @map("arg_of_pericenter")
  meanAnomaly        Float    @map("mean_anomaly")
  ephemerisType      Int?     @map("ephemeris_type")
  elementSetNo       String?  @map("element_set_no")
  revAtEpoch         String?  @map("rev_at_epoch")
  bstar              Float
  meanMotionDot      Float    @map("mean_motion_dot")
  meanMotionDdot     Float    @map("mean_motion_ddot")
  rawOmm             Json     @map("raw_omm")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([noradCatId, epoch])
  @@index([noradCatId])
  @@index([objectId])
  @@map("omm_records")
}
