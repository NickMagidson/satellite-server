{
  "name": "satellite-server-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspace apps/api run build",
    "db:generate": "npm --workspace packages/db run prisma:generate",
    "db:migrate": "npm --workspace packages/db run prisma:migrate",
    "db:studio": "npm --workspace packages/db run prisma:studio",
    "dev": "npm --workspace apps/api run dev",
    "typecheck": "npm --workspace apps/api run typecheck"
  }
}
